# VyapaarMind AI - Environment Template

# Supervity AI Bearer Token
SUPERVITY_BEARER_TOKEN="YOUR_SUPERVITY_BEARER_TOKEN"

# Firebase Config (Vite)
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="apps-xxxx.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="apps-xxxx"
VITE_FIREBASE_STORAGE_BUCKET="apps-xxxx.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="xxxxxxxxxx"
VITE_FIREBASE_APP_ID="1:xxxxxx:web:xxxxxx"

# API Configuration
VITE_API_URL="http://localhost:8000"

# Mail Configuration (For email notification triggers)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"

# Groq AI Configuration (Autonomous Decision Engine)
GROQ_API_KEY="your-groq-api-key-here"
